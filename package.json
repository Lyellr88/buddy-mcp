{
  "name": "@lyellr88/buddy-mcp",
  "version": "1.4.2",
  "description": "Gacha companion system for Claude Code. Collect, evolve, and patch your buddy via MCP",
  "type": "module",
  "bin": {
    "buddy-mcp": "./dist/mcp/index.js",
    "buddy-mcp-build": "./dist/tui/launcher.js"
  },
  "files": [
    "dist/",
    "assets/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:tools": "node tests/tools/test-pet-buddy.mjs && node tests/tools/reroll-buddy.mjs && node tests/tools/buddy-talk.mjs && node tests/tools/interact-mode.mjs && node tests/tools/buddy-dex.mjs",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/**/*.ts tests/**/*.ts",
    "format:check": "prettier --check src/**/*.ts tests/**/*.ts",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run build && npm run test",
    "serve": "node dist/mcp/index.js",
    "apply": "node dist/mcp/index.js apply",
    "builder": "node dist/tui/launcher.js",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lyell/buddy-mcp"
  },
  "keywords": [
    "claude",
    "claude-code",
    "buddy",
    "companion",
    "pet",
    "gacha",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Ryan Lyell",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@opentui/core": "*"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^3",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.7",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
}
